{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/tmp"
      ],
      "transport": "stdio",
      "enabled": true,
      "description": "Access to local filesystem"
    },
