# Balance Edge Service Configuration
# Copy this file to .env and fill in your values

# Machine identity — must match what the PUDA backend registers
MACHINE_ID=balance

# Serial port the balance is connected to
# Windows: COM8   Linux: /dev/ttyUSB0 or /dev/ttyACM0
BALANCE_PORT=/dev/ttyUSB0

# Serial settings (defaults work for Arduino load cells)
BAUDRATE=115200
MODE=arduino   # arduino | commercial

# Balance Bridge HTTP service (runs on the same machine as this edge)
BRIDGE_HOST=localhost
BRIDGE_PORT=9000

# NATS cluster (comma-separated server URLs)
NATS_SERVERS=nats://100.109.131.12:4222,nats://100.109.131.12:4223,nats://100.109.131.12:4224
